{
  "name": "outl-plugin-ouraring",
  "version": "2.0.0",
  "description": "outl plugin that syncs Oura Ring health data into daily pages.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=iife --platform=neutral --target=es2022 --sourcemap --outfile=index.js",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && esbuild src/index.ts --bundle --format=iife --platform=neutral --target=es2022 --outfile=index.js"
  },
  "dependencies": {
    "@outl/plugin-sdk": "^1.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.9.0"
  }
}
